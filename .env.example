# AIJobRadar Configuration
# Copy this file to .env and adjust values as needed.

# Cache time-to-live in minutes (default: 60)
CACHE_TTL_MINUTES=60

# HTTP request timeout in seconds (default: 15)
REQUEST_TIMEOUT_SECONDS=15

# Maximum jobs to return per scraper source (default: 100)
MAX_JOBS_PER_SOURCE=100

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Path to the JSON cache file (default: data/jobs_cache.json)
CACHE_FILE_PATH=data/jobs_cache.json

# User-Agent header for HTTP requests
USER_AGENT=Mozilla/5.0 (AIJobRadar/1.0; +https://github.com/YOUR_USERNAME/aijobradar)
